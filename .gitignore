# .gitignore for HarmonyOS + Claude Code Project
# 策略：只跟踪特定目录和文件

# ===========================================
# 1. 忽略所有应用代码目录
# ===========================================
harmony_chrp_app/

# ===========================================
# 2. 忽略 .claude 下的子模块和不需要的目录
# ===========================================
.claude/skills/arkts_skills/
.claude/skills/claude-arsenal/
.claude/skills/continuous-learning-v2/
.claude/backups/
.claude/cache/
.claude/debug/
.claude/homunculus/
.claude/metrics/
.claude/file-history/
.claude/history.jsonl
.claude/config.json

# ===========================================
# 3. 构建输出
# ===========================================
/build/
/build
**/build/
**/build

# ===========================================
# 4. IDE 和编辑器
# ===========================================
.idea/
.vscode/
*.iml

# ===========================================
# 5. Node 模块
# ===========================================
node_modules/
oh_modules/

# ===========================================
# 6. HarmonyOS 签名文件
# ===========================================
*.p12
*.p7b
*.cer
sign/*.p12
sign/*.p7b
sign/*.cer

# ===========================================
# 7. macOS 系统文件
# ===========================================
.DS_Store

# ===========================================
# 8. 日志文件
# ===========================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===========================================
# 9. 测试覆盖率
# ===========================================
coverage/

# ===========================================
# 10. 临时文件
# ===========================================
tmp/
.tmp/
.superpowers/
