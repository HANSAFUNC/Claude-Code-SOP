# .gitignore - 只跟踪指定目录和文件
# 策略：忽略所有，仅允许特定内容

# ===========================================
# 1. 忽略所有根目录文件和目录
# ===========================================
*

# ===========================================
# 2. 允许根目录特定文件
# ===========================================
!.gitignore
!README.md
!CLAUDE.md

# ===========================================
# 3. 允许 .claude 特定子目录
# ===========================================
!.claude/
.claude/*
!.claude/agents/
!.claude/rules/
!.claude/skills/
!.claude/teams/
!.claude/CLAUDE.md
!.claude/settings.json
!.claude/keybindings.json

# .claude 下忽略的目录

.claude/backups/
.claude/cache/
.claude/debug/
.claude/homunculus/
.claude/metrics/
.claude/file-history/
.claude/history.jsonl
.claude/config.json

# ===========================================
# 4. 允许 Architect 目录
# ===========================================
!Architect/

# ===========================================
# 5. 允许 Design 目录
# ===========================================
!Design/

# ===========================================
# 6. 允许 Docs 目录
# ===========================================
!Docs/

# ===========================================
# 7. 允许 PRD 目录
# ===========================================
!PRD/

# ===========================================
# 8. 忽略所有应用目录 (任何可能的名字)
# ===========================================
# HarmonyOS 应用目录
*.app/
app/
apps/
application/
applications/
*app/
*_app/

# 常见应用目录名
harmony*/
Harmony*/
mobile/
Mobile/
client/
Client/
source/
Source/
src/
Source/

# ===========================================
# 9. 构建输出
# ===========================================
build/
Build/
BUILD/
**/build/**
**/Build/**
**/BUILD/**
dist/
Dist/
output/
Output/

# ===========================================
# 10. IDE 和编辑器
# ===========================================
.idea/
.vscode/
*.iml
*.swp
*.swo
*~

# ===========================================
# 11. Node 模块
# ===========================================
node_modules/
oh_modules/

# ===========================================
# 12. 签名和证书
# ===========================================
*.p12
*.p7b
*.cer
*.keystore
*.jks
sign/
Sign/
.keystore/

# ===========================================
# 13. 系统文件
# ===========================================
.DS_Store
Thumbs.db
desktop.ini

# ===========================================
# 14. 日志文件
# ===========================================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===========================================
# 15. 测试覆盖率
# ===========================================
coverage/
Coverage/
.nyc_output/

# ===========================================
# 16. 临时文件
# ===========================================
tmp/
Tmp/
.temp/
.tmp/
.cache/
.Cache/
.superpowers/

# ===========================================
# 17. 环境文件
# ===========================================
.env
.env.*
!.env.example
*.local
