{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enabledPlugins": {
    "everything-claude-code@everything-claude-code": true,
    "superpowers@claude-plugins-official": true
  },
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "sk-sp-772a1c2451ad4366a2620c466685f8c3",
    "ANTHROPIC_BASE_URL": "https://coding.dashscope.aliyuncs.com/apps/anthropic",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "qwen3.5-plus",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "qwen3.5-plus",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "qwen3.5-plus",
    "ANTHROPIC_MODEL": "qwen3.5-plus",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "qwen3.5-plus"
  },
  "hasCompletedOnboarding": true,
  "hooks": {
      "PreToolUse": [{
            "matcher": "*",
            "hooks": [{
              "type": "command",
              "command": "~/.claude/skills/continuous-learning-v2/hooks/observe.sh"
            }]
          }],
          "PostToolUse": [{
            "matcher": "*",
            "hooks": [{
              "type": "command",
              "command": "~/.claude/skills/continuous-learning-v2/hooks/observe.sh"
            }]
          }]
    
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run test *)",
      "Bash(npm run build)",
      "Bash(npm run typecheck)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(ls *)",
      "Bash(grep -*)",
      "Bash",
      "Read",
      "Edit",
      "Write",
      "Grep",
      "Search"
    ],
    "ask": [
      "Bash(git push --force *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Bash(rm -rf *)",
      "Bash(curl *)"
    ]
  },
  "primaryApiKey": "self",
  "teammateMode": "in-process"
}
