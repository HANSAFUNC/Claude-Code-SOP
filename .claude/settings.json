{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enabledPlugins": {
    "everything-claude-code@everything-claude-code": true,
    "superpowers@claude-plugins-official": true
  },
  "hasCompletedOnboarding": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/skills/continuous-learning-v2/hooks/observe.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/skills/continuous-learning-v2/hooks/observe.sh"
          }
        ]
      }
    ]
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run test *)",
      "Bash(npm run build)",
      "Bash(npm run typecheck)",
      "Bash(git commit *)",
      "Bash(ls *)",
      "Bash(grep -*)",
      "Bash",
      "Read",
      "Edit",
      "Write",
      "Grep",
      "Search"
    ],
    "ask": [
      "Bash(git push --force *)",
      "Bash(npm install *)",
      "Bash(pip install *)",
      "Bash(git merge *)",
      "Bash(git rebase *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Bash(rm -rf *)",
      "Read(**/*credential*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Bash(git push *)",
      "Bash(git rebase -i *)",
      "Bash(kill *)",
      "Bash(pkill *)",
      "Bash(systemctl *)"
    ]
  },
  "primaryApiKey": "self",
  "teammateMode": "in-process"
}
